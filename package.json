    "dev": "echo 'Run \"npm run frontend\" and \"npm run backend\" in separate terminals for now.'"
  },
  "keywords": [
    "streetwear",
    "ecommerce",
    "nextjs",
    "django"
  ],
  "author": "Athnic Clothing",
