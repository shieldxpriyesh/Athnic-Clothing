{
  "name": "athnic-clothing",
  "version": "1.0.0",
  "description": "Athnic Clothing E-commerce Platform",
  "scripts": {
    "frontend": "npm run dev --prefix frontend",
    "backend": "cd backend && ./venv/bin/python3 manage.py runserver",
